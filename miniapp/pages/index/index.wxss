.debug-panel {
  background: #fff9e6;
  border: 2rpx solid #e6c300;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.debug-title {
  font-weight: 700;
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.debug-line {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.debug-input {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
}

.debug-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.small-button {
  margin: 0;
  flex: 1;
}

.hero,
.search-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.mini-link,
.search-button {
  margin: 0;
}

.search-input {
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.category-strip {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-row {
  display: inline-flex;
  gap: 16rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 242, 0.94);
}

.category-pill.active {
  background: #2d2623;
  color: #fff5ec;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  display: flex;
  gap: 18rpx;
}

.product-image {
  width: 220rpx;
  height: 180rpx;
  border-radius: 18rpx;
}

.product-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.category-label {
  color: #9a502a;
  font-weight: 700;
}

.product-title {
  font-size: 32rpx;
  font-weight: 700;
}

.price {
  font-weight: 700;
}

.sold-out.ok {
  color: #2d7d4c;
}

.sold-out.warn,
.error {
  color: #ad3724;
}
