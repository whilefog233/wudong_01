.hero-card,
.search-panel,
.product-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(31, 95, 168, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
}

.stat-label {
  color: #5d748c;
  font-size: 22rpx;
}

.quick-nav {
  display: flex;
  gap: 16rpx;
}

.nav-button,
.search-button {
  flex: 1;
  margin: 0;
}

.hot-searches {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 95, 168, 0.08);
  color: #1f5fa8;
}

.category-strip {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-row {
  display: inline-flex;
  gap: 16rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #5d748c;
}

.category-pill.active {
  background: #1f5fa8;
  color: #ffffff;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  flex-direction: row;
  align-items: stretch;
}

.product-image {
  width: 220rpx;
  height: 210rpx;
  border-radius: 22rpx;
}

.product-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.product-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
}

.stock.ok {
  color: #2d7d4c;
}

.stock.warn {
  color: #ad3724;
}
