.profile-card,
.login-card,
.section-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
}

.mini-card {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(31, 95, 168, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-number {
  font-size: 38rpx;
  font-weight: 700;
}

.login-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-button {
  flex: 1;
  margin: 0;
}

.order-row,
.address-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 0;
  border-top: 1px solid rgba(23, 50, 78, 0.08);
}

.order-meta {
  display: flex;
  justify-content: space-between;
}
