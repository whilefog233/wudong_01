.address-card,
.cart-item,
.submit-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.cart-image {
  width: 100%;
  height: 260rpx;
  border-radius: 18rpx;
}

.cart-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.cart-title {
  font-size: 34rpx;
  font-weight: 700;
}

.cart-price {
  font-size: 32rpx;
  font-weight: 700;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-button,
.remove-button,
.submit-button {
  margin: 0;
}
