page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(31, 95, 168, 0.1), transparent 30%),
    linear-gradient(180deg, #f7fbff 0%, #eef4fb 100%);
  color: #17324e;
  font-size: 28rpx;
}

.shell {
  padding: 24rpx;
}

.panel {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 18rpx 50rpx rgba(14, 61, 117, 0.08);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  color: #5d748c;
}

.eyebrow {
  color: #1f5fa8;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.muted {
  color: #5d748c;
}

.button-primary {
  background: linear-gradient(120deg, #1f5fa8, #0e3d75);
  color: #ffffff;
  border-radius: 999rpx;
}

.button-ghost {
  border-radius: 999rpx;
  border: 1px solid rgba(23, 50, 78, 0.14);
  background: rgba(255, 255, 255, 0.94);
  color: #17324e;
}

.field {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(31, 95, 168, 0.05);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.message {
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(232, 93, 47, 0.08);
  color: #a54827;
}
